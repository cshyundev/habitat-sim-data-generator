<?xml version="1.0"?>
<!-- Default cylinder robot with sensor mount frames. Convention: ROS REP-103 (Z-up, X-forward). -->
<!-- Body geometry matches src.robot.cylinder_urdf(height=0.5, radius=0.25). -->
<robot name="cylinder_robot">
  <!-- Cylindrical body: base sits on the floor plane (z in [0, 0.5]). -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.5"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.25" length="0.5"/>
      </geometry>
    </collision>
  </link>

  <!-- 3D ideal LiDAR mounted at the top centre of the cylinder. -->
  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- Forward camera frame. -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="-0.1 0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- IMU frame at the base origin. -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
